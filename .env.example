# Copy to .env and review every value before use.
# No real credentials or patient data belong in this file, ever.

ENVIRONMENT=development
LOG_LEVEL=INFO

# Postgres (used by docker-compose to provision the local container)
POSTGRES_USER=clinic
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=clinic_admin

# Backend (used by the backend service directly; must match the Postgres values above)
DATABASE_URL=postgresql+psycopg://clinic:change-me-local-only@localhost:5432/clinic_admin
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# Backend test suite (integration tests only): a SEPARATE, disposable
# database the test suite is allowed to drop/recreate tables in. Must never
# equal DATABASE_URL above, and its database name must end with "_test" or
# contain "test" - backend/tests/db_safety.py refuses to run otherwise, with
# no automatic fallback to DATABASE_URL and no script that derives or
# authorizes this on its own. For local Docker development, prefer running
# `.ai-workflow/scripts/run-local-integration-tests.ps1` instead of setting
# these by hand: it starts the repository's own dedicated, disposable
# `postgres-test` Compose service and sets both variables itself only after
# verifying that service's identity. Set these explicitly yourself only for
# CI or a non-Docker local Postgres - see README.md -> "Running tests".
TEST_DATABASE_URL=postgresql+psycopg://clinic:change-me-local-only@localhost:5432/clinic_admin_test
# Second, independent opt-in required (on top of the test-like database
# name above) before the test suite will run its destructive drop_all/
# create_all setup. Leave unset/false unless you are about to run the
# backend integration test suite locally.
ALLOW_DESTRUCTIVE_TEST_DB_RESET=false

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Multi-tenant foundation: development-only identity provider.
# Must stay false in any environment where ENVIRONMENT != development —
# the backend refuses to start otherwise. When true, tenant-scoped routes
# trust the X-Dev-User-Id and X-Tenant-Id request headers as a CLAIM (still
# re-validated against the database on every request), not as
# authorization. See README.md -> "Multi-tenant foundation" and
# SECURITY.md -> "Development identity restrictions".
DEVELOPMENT_IDENTITY_ENABLED=false
